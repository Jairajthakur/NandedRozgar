# ── Secrets — never commit real env files ─────────────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Firebase / Google ─────────────────────────────────────────────────────────
# google-services.json is intentionally tracked as a placeholder.
# The CI workflow (build-apk.yml) overwrites it with the real secret at build
# time so that EAS local builds can include it in the project archive.
# GoogleService-Info.plist (iOS) is not used and stays ignored.
GoogleService-Info.plist

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Expo / React Native ───────────────────────────────────────────────────────
.expo/
dist/
web-build/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ── Build outputs ─────────────────────────────────────────────────────────────
android/
ios/
*.apk
*.aab
*.ipa

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
