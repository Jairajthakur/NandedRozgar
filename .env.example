# ── CityPlus — Environment Variables Template ─────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is listed in .gitignore.
# For production, store all secrets in EAS Secrets or Railway environment variables.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development          # Set to "production" on Railway / EAS

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED — server will refuse to start if missing
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── Admin account ─────────────────────────────────────────────────────────────
# Use a bcrypt hash here: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_EMAIL=admin@cityplus.app
ADMIN_PASSWORD=$2a$12$REPLACE_WITH_BCRYPT_HASH_OF_YOUR_PASSWORD

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (in addition to the Railway default)
CORS_ORIGINS=https://yourdomain.com,https://cityplus.app

# ── App URL (used in password-reset emails) ───────────────────────────────────
APP_URL=https://cityplus.app

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
# Paste the entire JSON as a single line (escape quotes if needed), OR use GOOGLE_APPLICATION_CREDENTIALS
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json  # alternative

# ── Firebase client-side (Expo public — safe to expose to the app bundle) ─────
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_WEB_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:android:xxxxxxxxxxxxxxxx
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Development: rzp_test_…  |  Production: rzp_live_… (requires KYC on Razorpay dashboard)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_SECRET  # backend only, never expose to client

# ── SMS OTP (Fast2SMS — India) ────────────────────────────────────────────────
FAST2SMS_API_KEY=REPLACE_WITH_YOUR_FAST2SMS_KEY
FAST2SMS_ROUTE=otp                # 'otp' or 'dlt'
# FAST2SMS_SENDER_ID=CITYPL       # required for DLT route only
# FAST2SMS_TEMPLATE_ID=123456     # required for DLT route only

# ── Email (Resend — https://resend.com) ───────────────────────────────────────
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=noreply@cityplus.app
