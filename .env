# ─────────────────────────────────────────────────────────────────────────────
# NandedRozgar — environment variable template
#
# DO NOT commit real secrets to this file.
# Set all values directly in Railway → Variables (server-side secrets).
# Client-side vars (EXPO_PUBLIC_*) can also go in .env.local for local dev.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://your-railway-app.up.railway.app

# ── Google OAuth ──────────────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=947711727855-vs3scmgk4n7e73gdc2siskqd9d538tas.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=947711727855-ucqjm9eoh41khqj3hc5ppn0r5tb4k60c.apps.googleusercontent.com

# ── Firebase ──────────────────────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_APP_ID=1:your_project_number:android:your_app_id
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PROJECT_ID=fe9ac0b4-a7e8-4153-85c1-49df63f00b16

# ── Server-side secrets (Railway env vars ONLY — never commit values here) ───
#
# DATABASE_URL=          # postgresql://user:password@host:5432/db
# JWT_SECRET=            # generate: openssl rand -hex 32
# ADMIN_EMAIL=           # admin login email
# ADMIN_PASSWORD=        # bcrypt hash only
# APP_URL=               # e.g. https://thecityplus.in  (no trailing slash)
#
# ── Cashfree (Payment Gateway) ───────────────────────────────────────────────
# Get these from: https://merchant.cashfree.com → Developers → API Keys
# Production keys go here. For sandbox testing, use the sandbox dashboard:
# https://test.cashfree.com → Developers → API Keys
#
# CASHFREE_APP_ID=       # e.g.  123456789012345678901234
# CASHFREE_SECRET_KEY=   # e.g.  cfsk_ma_prod_xxxxxxxxxxxxxxxxxxxx
#
# ── Other services ───────────────────────────────────────────────────────────
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=     # e.g. noreply@thecityplus.in
# FIREBASE_SERVICE_ACCOUNT=  # full JSON of your Firebase service account key
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# GOOGLE_ANDROID_CLIENT_ID=
# CORS_ORIGINS=          # comma-separated extra allowed origins
