# ─────────────────────────────────────────────────────────────────────────────
# NandedRozgar — environment variable template
#
# DO NOT commit real secrets to this file.
# Copy this to .env.local (or set vars directly in Railway / EAS) and fill in
# your actual values. .env.local is listed in .gitignore and never committed.
#
# !! SECURITY NOTICE !!
# The previous version of this file had real credentials in comments.
# Those values have been rotated and are no longer valid:
#   - JWT_SECRET       → generate a new 32-char secret:  openssl rand -hex 32
#   - ADMIN_PASSWORD   → set a new strong password; store only its bcrypt hash
#   - RAZORPAY_KEY_SECRET → regenerate in the Razorpay Dashboard
#   - DATABASE_URL     → rotate the DB password in your Railway Postgres settings
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://your-railway-app.up.railway.app

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Found in Google Cloud Console → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Public key (safe to expose to client); secret key goes in Railway only
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# ── Firebase ──────────────────────────────────────────────────────────────────
# Found in Firebase Console → Project Settings → Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_APP_ID=1:your_project_number:android:your_app_id
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# ── Server-side secrets (Railway env vars ONLY — never store values here) ────
# Set each of these in Railway → Variables, not in any committed file.
#
# DATABASE_URL=          # postgresql://user:password@host:5432/db
# JWT_SECRET=            # generate: openssl rand -hex 32
# ADMIN_EMAIL=           # admin login email
# ADMIN_PASSWORD=        # bcrypt hash only — see auth.js for instructions
# RAZORPAY_KEY_SECRET=   # from Razorpay Dashboard → API Keys
# RESEND_API_KEY=        # from resend.com → API Keys
# RESEND_FROM_EMAIL=     # e.g. noreply@thecityplus.in
# FIREBASE_SERVICE_ACCOUNT=  # full JSON of your service account key
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# APP_URL=https://thecityplus.in
